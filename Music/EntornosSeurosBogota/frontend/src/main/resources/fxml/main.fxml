<!-- Archivo: src/main/resources/fxml/main.fxml -->
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.entornosseguros.ui.MainController"
            prefHeight="800" prefWidth="1200">

    <!-- Header/TopBar -->
    <top>
        <HBox style="-fx-background-color: #001F3F; -fx-padding: 15;" spacing="10" alignment="CENTER_LEFT">
            <Label text="🛡️ Entornos Seguros Bogotá"
                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 18; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- Contenido Principal -->
    <center>
        <VBox style="-fx-background-color: #F5F5F5;" spacing="20" alignment="CENTER">
            <Label text="Sistema Inteligente de Reportes de Seguridad"
                   style="-fx-font-size: 24; -fx-text-fill: #001F3F;"/>
            <Label text="Bogotá Camina Segura"
                   style="-fx-font-size: 14; -fx-text-fill: #666666;"/>
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="reportButton" text="Reportar Incidente"
                        style="-fx-padding: 10; -fx-font-size: 14;"
                        onAction="#onReportarIncidente"/>
                <Button fx:id="mapButton" text="Ver Mapa"
                        style="-fx-padding: 10; -fx-font-size: 14;"
                        onAction="#onVerMapa"/>
                <Button fx:id="dashboardButton" text="Dashboard"
                        style="-fx-padding: 10; -fx-font-size: 14;"
                        onAction="#onAbrirDashboard"/>
            </HBox>
        </VBox>
    </center>

    <!-- Footer -->
    <bottom>
        <HBox style="-fx-background-color: #F5F5F5; -fx-border-top: 1px solid #CCCCCC; -fx-padding: 10;" alignment="CENTER_LEFT">
            <Label text="© 2026 Entornos Seguros Bogotá - Secretaría Distrital de Seguridad"
                   style="-fx-font-size: 10; -fx-text-fill: #666666;"/>
        </HBox>
    </bottom>
</BorderPane>
